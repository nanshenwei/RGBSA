{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SARGB",
            "type": "shell",
            "command": "make",
            "args": [
                "SARGB_52832"
            ],
            "options": {
                "cwd": "${workspaceFolder}/firmware"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}/firmware"
            },
            "problemMatcher": []
        },
        {
            "label": "Flash SARGB",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/ultralink-NRF52.cfg",
                "-f", "target/nrf52.cfg",
                "-c", "init; halt; nrf52_flash_bank_erase 0; flash write_image build/SARGB_52832.hex; reset; exit"
            ],
            "options": {
                "cwd": "${workspaceFolder}/firmware"
            },
            "dependsOn": "Build SARGB",
            "problemMatcher": []
        }
    ]
}